{
	"name": "behkhaan-api",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"engines": {
		"node": ">=22"
	},
	"packageManager": "npm@11.12.1",
	"engineStrict": true,
	"scripts": {
		"build": "nest build",
		"start": "nest start -b swc",
		"start:dev": "nest start -b swc -w",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main.js",
		"check": "npx @biomejs/biome check --write",
		"prepare": "husky | true",
		"commit": "cz",
		"docker:dev": "docker compose -f docker-compose.dev.yml up",
		"docker": "docker compose -f docker-compose.yml up"
	},
	"dependencies": {
		"@adminjs/express": "^6.1.1",
		"@adminjs/nestjs": "^7.0.0",
		"@adminjs/typeorm": "^5.0.1",
		"@nestjs/common": "^11.1.27",
		"@nestjs/config": "^4.0.4",
		"@nestjs/core": "^11.1.27",
		"@nestjs/mapped-types": "^2.1.1",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-express": "^11.1.27",
		"@nestjs/swagger": "^11.4.4",
		"@nestjs/typeorm": "^11.0.3",
		"@swc/helpers": "^0.5.23",
		"adminjs": "^7.8.17",
		"argon2": "^0.44.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.15.1",
		"connect-typeorm": "^2.0.0",
		"express-formidable": "^1.2.0",
		"express-session": "^1.19.0",
		"fast-json-patch": "^3.1.1",
		"helmet": "^8.2.0",
		"passport": "^0.7.0",
		"passport-local": "^1.0.0",
		"pg": "^8.22.0",
		"pino-http": "^10.5.0",
		"pino-nestjs": "^0.1.3",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"swagger-themes": "^1.4.3",
		"typeorm": "^0.3.30",
		"zod": "^4.4.3",
		"zod-validation-error": "^5.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.0.1",
		"@swc/cli": "^0.8.1",
		"@swc/core": "^1.15.43",
		"@types/express": "^5.0.0",
		"@types/express-session": "^1.19.0",
		"@types/node": "^24.0.0",
		"@types/passport-local": "^1.0.38",
		"@types/supertest": "^7.0.0",
		"chokidar": "^5.0.0",
		"cz-conventional-changelog": "^3.3.0",
		"husky": "^9.1.7",
		"pino-pretty": "^13.1.3",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.7.3"
	},
	"imports": {
		"#config/*": "./dist/config/*",
		"#enums/*": "./dist/common/enums/*",
		"#constants/*": "./dist/common/constants/*",
		"#regex/*": "./dist/common/regex/*",
		"#decorators/*": "./dist/common/decorators/*",
		"#modules/*": "./dist/modules/*",
		"#database/*": "./dist/database/*",
		"#bootstrap/*": "./dist/bootstrap/*",
		"#guards/*": "./dist/common/guards/*",
		"#pipes/*": "./dist/common/pipes/*"
	},
	"allowScripts": {
		"unrs-resolver@1.12.2": true,
		"esbuild@0.25.12": true,
		"@swc/core@1.15.43": true,
		"@scarf/scarf@1.4.0": true,
		"argon2@0.44.0": true
	}
}
