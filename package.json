{
	"name": "behkhaan-api",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"engines": {
		"node": ">=22"
	},
	"packageManager": "npm@11.12.1",
	"engineStrict": true,
	"scripts": {
		"build": "nest build",
		"start": "nest --env-file=./env/.env.production start -b swc",
		"start:dev": "nest --env-file=./env/.env.development start -b swc -w",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node --env-file=./env/.env.production dist/main",
		"check": "npx @biomejs/biome check --write",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./test/jest-e2e.json",
		"prepare": "husky",
		"commit": "cz"
	},
	"dependencies": {
		"@adminjs/express": "^6.1.1",
		"@adminjs/nestjs": "^7.0.0",
		"@adminjs/typeorm": "^5.0.1",
		"@nestjs/common": "^11.1.27",
		"@nestjs/config": "^4.0.4",
		"@nestjs/core": "^11.1.27",
		"@nestjs/platform-express": "^11.1.27",
		"@nestjs/swagger": "^11.4.4",
		"@swc/helpers": "^0.5.23",
		"adminjs": "^7.8.17",
		"express-formidable": "^1.2.0",
		"express-session": "^1.19.0",
		"helmet": "^8.2.0",
		"pino-http": "^10.5.0",
		"pino-nestjs": "^0.1.3",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"swagger-themes": "^1.4.3",
		"zod": "^4.4.3",
		"zod-validation-error": "^5.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.0.1",
		"@swc/cli": "^0.8.1",
		"@swc/core": "^1.15.43",
		"@types/express": "^5.0.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^24.0.0",
		"@types/supertest": "^7.0.0",
		"chokidar": "^5.0.0",
		"cz-conventional-changelog": "^3.3.0",
		"globals": "^17.0.0",
		"husky": "^9.1.7",
		"jest": "^30.0.0",
		"pino-pretty": "^13.1.3",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.7.3"
	},
	"imports": {
		"#config/*": "./dist/config/*",
		"#enums/*": "./dist/common/enums/*",
		"#constants/*": "./dist/common/constants/*"
	},
	"allowScripts": {
		"unrs-resolver@1.12.2": true,
		"esbuild@0.25.12": true,
		"@swc/core@1.15.43": true,
		"@scarf/scarf@1.4.0": true
	}
}
