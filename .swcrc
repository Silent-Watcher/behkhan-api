{
	"$schema": "https://swc.rs/schema.json",
	"sourceMaps": true,
	"jsc": {
		"target": "es2022",
		"keepClassNames": true,
		"preserveAllComments": false,
		"externalHelpers": true,
		"parser": {
			"syntax": "typescript",
			"decorators": true,
			"dynamicImport": true
		},
		"baseUrl": "./"
	},
	"minify": true
}
