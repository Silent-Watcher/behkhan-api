{
	"$schema": "https://swc.rs/schema.json",
	"sourceMaps": true,
	"jsc": {
		"target": "es2022",
		"keepClassNames": true,
		"preserveAllComments": false,
		"transform": {
			"decoratorMetadata": true
		},
		"externalHelpers": true,
		"parser": {
			"syntax": "typescript",
			"decorators": true,
			"dynamicImport": true
		},
		"baseUrl": "./"
	},
    "module":{
        "type": "es6"
    },
	"minify": true
}
